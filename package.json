{
  "name": "stablecoin",
  "version": "1.0.0",
  "description": "VietRSD Stablecoin implementation using OnChainDB",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "cli": "ts-node src/index.ts",
    "setup": "ts-node src/index.ts setup",
    "mint": "ts-node src/index.ts mint",
    "burn": "ts-node src/index.ts burn",
    "transfer": "ts-node src/index.ts transfer",
    "balance": "ts-node src/index.ts balance",
    "supply": "ts-node src/index.ts supply",
