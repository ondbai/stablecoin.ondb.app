# OnChainDB Configuration
ONCHAINDB_ENDPOINT=https://api.onchaindb.io
ONCHAINDB_APP_ID=your-app-id
ONCHAINDB_APP_KEY=your-app-key
ONCHAINDB_USER_KEY=your-user-key

# Stablecoin Configuration
STABLECOIN_NAME=VietRSD
STABLECOIN_SYMBOL=VRSD
STABLECOIN_DECIMALS=6

# Security Configuration
# Admin address - automatically added to authorized minters
ADMIN_ADDRESS=celestia1...

# Comma-separated list of additional Celestia addresses authorized to mint new tokens
# ADMIN_ADDRESS is automatically included, so you only need to add additional minters here
AUTHORIZED_MINTERS=

# Allow unrestricted minting - defaults to 'false' for security
# Only set to 'true' for local development/testing
ALLOW_UNRESTRICTED_MINT=false

# Require cryptographic signatures for transfer and burn operations
# Set to 'false' for development/testing without wallet integration
# In production, this should be 'true' (or omitted, as true is the default)
REQUIRE_SIGNATURES=true

# Chain ID used for transaction signatures (must match frontend)
CHAIN_ID=stablecoin-utxo-v1
